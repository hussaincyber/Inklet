<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_editor"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_editor_bg">

    <!-- Left wood panel -->
    <ImageView
        android:id="@+id/wood_left"
        android:layout_width="@dimen/wood_panel_width"
        android:layout_height="match_parent"
        android:layout_alignParentStart="true"
        android:src="@drawable/wood_texture"
        android:scaleType="centerCrop" />

    <!-- Right wood panel -->
    <ImageView
        android:id="@+id/wood_right"
        android:layout_width="@dimen/wood_panel_width"
        android:layout_height="match_parent"
        android:layout_alignParentEnd="true"
        android:src="@drawable/wood_texture"
        android:scaleType="centerCrop" />

    <!-- Editor content between panels -->
    <LinearLayout
        android:id="@+id/editor_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_toEndOf="@id/wood_left"
        android:layout_toStartOf="@id/wood_right"
        android:orientation="vertical"
        android:background="@color/light_editor_bg">

        <!-- Toolbar -->
        <RelativeLayout
            android:id="@+id/editor_toolbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/toolbar_height"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:background="@color/light_toolbar_bg">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_back"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:tint="@color/light_text_primary"
                android:contentDescription="Back" />

            <TextView
                android:id="@+id/tv_save_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Saved"
                android:fontFamily="sans-serif"
                android:textSize="12sp"
                android:textColor="@color/light_text_secondary"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btn_save"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_save"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:tint="@color/light_text_primary"
                    android:contentDescription="Save" />

                <ImageButton
                    android:id="@+id/btn_delete"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_delete"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:tint="@color/light_text_primary"
                    android:contentDescription="Delete" />
            </LinearLayout>

        </RelativeLayout>

        <!-- Thin divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/light_divider" />

        <!-- Title -->
        <EditText
            android:id="@+id/et_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"
            android:hint="Title"
            android:fontFamily="serif"
            android:textSize="22sp"
            android:textColor="@color/light_text_primary"
            android:textColorHint="@color/light_divider"
            android:background="@null"
            android:inputType="textCapSentences"
            android:maxLines="2"
            android:imeOptions="actionNext" />

        <!-- Thin divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/light_divider"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp" />

        <!-- Format bar (scrollable) -->
        <HorizontalScrollView
            android:id="@+id/format_scroll"
            android:layout_width="match_parent"
            android:layout_height="@dimen/format_bar_height"
            android:scrollbars="none"
            android:background="@color/light_toolbar_bg">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:gravity="center_vertical">

                <!-- Bold -->
                <ImageButton
                    android:id="@+id/btn_bold"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:src="@drawable/ic_bold"
                    android:background="@drawable/bg_format_btn"
                    android:tint="@color/light_text_primary"
                    android:contentDescription="Bold" />

                <!-- Italic -->
                <ImageButton
                    android:id="@+id/btn_italic"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_italic"
                    android:background="@drawable/bg_format_btn"
                    android:tint="@color/light_text_primary"
                    android:contentDescription="Italic" />

                <!-- Underline -->
                <ImageButton
                    android:id="@+id/btn_underline"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_underline"
                    android:background="@drawable/bg_format_btn"
                    android:tint="@color/light_text_primary"
                    android:contentDescription="Underline" />

                <!-- Strikethrough -->
                <ImageButton
                    android:id="@+id/btn_strike"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_strikethrough"
                    android:background="@drawable/bg_format_btn"
                    android:tint="@color/light_text_primary"
                    android:contentDescription="Strikethrough" />

                <!-- Separator -->
                <View android:layout_width="1dp" android:layout_height="24dp"
                    android:background="@color/light_divider" android:layout_marginStart="6dp" android:layout_marginEnd="6dp" />

                <!-- Font size -->
                <ImageButton
                    android:id="@+id/btn_size"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:src="@drawable/ic_text_size"
                    android:background="@drawable/bg_format_btn"
                    android:tint="@color/light_text_primary"
                    android:contentDescription="Font size" />

                <!-- Font family -->
                <ImageButton
                    android:id="@+id/btn_font"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_font"
                    android:background="@drawable/bg_format_btn"
                    android:tint="@color/light_text_primary"
                    android:contentDescription="Font family" />

                <!-- Separator -->
                <View android:layout_width="1dp" android:layout_height="24dp"
                    android:background="@color/light_divider" android:layout_marginStart="6dp" android:layout_marginEnd="6dp" />

                <!-- Text color -->
                <ImageButton
                    android:id="@+id/btn_text_color"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:src="@drawable/ic_text_color"
                    android:background="@drawable/bg_format_btn"
                    android:tint="@color/light_text_primary"
                    android:contentDescription="Text color" />

                <!-- Background/highlight color -->
                <ImageButton
                    android:id="@+id/btn_bg_color"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_highlight"
                    android:background="@drawable/bg_format_btn"
                    android:tint="@color/light_text_primary"
                    android:contentDescription="Highlight" />

                <!-- Separator -->
                <View android:layout_width="1dp" android:layout_height="24dp"
                    android:background="@color/light_divider" android:layout_marginStart="6dp" android:layout_marginEnd="6dp" />

                <!-- Bullet -->
                <ImageButton
                    android:id="@+id/btn_bullet"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:src="@drawable/ic_bullet"
                    android:background="@drawable/bg_format_btn"
                    android:tint="@color/light_text_primary"
                    android:contentDescription="Bullet list" />

                <!-- Numbered list -->
                <ImageButton
                    android:id="@+id/btn_number"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_numbered"
                    android:background="@drawable/bg_format_btn"
                    android:tint="@color/light_text_primary"
                    android:contentDescription="Numbered list" />

                <!-- Separator -->
                <View android:layout_width="1dp" android:layout_height="24dp"
                    android:background="@color/light_divider" android:layout_marginStart="6dp" android:layout_marginEnd="6dp" />

                <!-- Image -->
                <ImageButton
                    android:id="@+id/btn_image"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:src="@drawable/ic_image"
                    android:background="@drawable/bg_format_btn"
                    android:tint="@color/light_text_primary"
                    android:contentDescription="Insert image" />

                <!-- Clear format -->
                <ImageButton
                    android:id="@+id/btn_clear_format"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_clear_format"
                    android:background="@drawable/bg_format_btn"
                    android:tint="@color/light_text_primary"
                    android:contentDescription="Clear formatting" />

            </LinearLayout>
        </HorizontalScrollView>

        <!-- Thin divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/light_divider" />

        <!-- Note content -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <EditText
                android:id="@+id/et_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="14dp"
                android:paddingBottom="40dp"
                android:hint="Start writing…"
                android:fontFamily="sans-serif"
                android:textSize="15sp"
                android:textColor="@color/light_text_primary"
                android:textColorHint="@color/light_text_secondary"
                android:background="@null"
                android:gravity="top"
                android:inputType="textMultiLine|textCapSentences"
                android:lineSpacingMultiplier="1.5" />

        </ScrollView>

    </LinearLayout>

</RelativeLayout>

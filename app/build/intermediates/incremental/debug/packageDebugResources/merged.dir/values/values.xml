<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="black">#000000</color>
    <color name="colorAccent">#3D2B1F</color>
    <color name="colorPrimary">#1A1008</color>
    <color name="colorPrimaryDark">#0D0D0D</color>
    <color name="dark_accent">#FFFFFF</color>
    <color name="dark_bg">#0D0D0D</color>
    <color name="dark_card_bg">#1C1C1C</color>
    <color name="dark_divider">#2A2A2A</color>
    <color name="dark_editor_bg">#111111</color>
    <color name="dark_fab_bg">#FFFFFF</color>
    <color name="dark_fab_icon">#0D0D0D</color>
    <color name="dark_search_bg">#1C1C1C</color>
    <color name="dark_surface">#161616</color>
    <color name="dark_text_primary">#F0F0F0</color>
    <color name="dark_text_secondary">#888888</color>
    <color name="dark_toolbar_bg">#0D0D0D</color>
    <color name="light_accent">#3D2B1F</color>
    <color name="light_bg">#FDF6EC</color>
    <color name="light_card_bg">#FFFCF5</color>
    <color name="light_divider">#E8D5B7</color>
    <color name="light_editor_bg">#FFFDF8</color>
    <color name="light_fab_bg">#2C1A0E</color>
    <color name="light_fab_icon">#FDF6EC</color>
    <color name="light_search_bg">#F0E4CC</color>
    <color name="light_surface">#FAF0E0</color>
    <color name="light_text_primary">#1A1008</color>
    <color name="light_text_secondary">#6B4C2A</color>
    <color name="light_toolbar_bg">#FDF6EC</color>
    <color name="white">#FFFFFF</color>
    <dimen name="card_corner_radius">6dp</dimen>
    <dimen name="format_bar_height">48dp</dimen>
    <dimen name="toolbar_height">56dp</dimen>
    <dimen name="wood_panel_width">52dp</dimen>
    <string name="app_name">Inklet</string>
    <string name="empty_state">No notes yet.\nTap + to begin.</string>
    <string name="new_note">New Note</string>
    <string name="search_notes">Search notes…</string>
    <style name="AlertDialogTheme" parent="Theme.AppCompat.Light.Dialog.Alert">
        <item name="colorPrimary">@color/light_accent</item>
        <item name="android:background">@color/light_card_bg</item>
        <item name="android:textColorPrimary">@color/light_text_primary</item>
    </style>
    <style name="AlertDialogTheme.Dark" parent="Theme.AppCompat.Dialog.Alert">
        <item name="colorPrimary">@color/dark_accent</item>
        <item name="android:background">@color/dark_card_bg</item>
        <item name="android:textColorPrimary">@color/dark_text_primary</item>
    </style>
    <style name="Theme.Inklet" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/light_accent</item>
        <item name="colorPrimaryDark">@color/light_bg</item>
        <item name="colorAccent">@color/light_accent</item>
        <item name="android:windowBackground">@color/light_bg</item>
        <item name="android:statusBarColor">@color/light_bg</item>
        <item name="android:navigationBarColor">@color/light_bg</item>
        <item name="android:textColorPrimary">@color/light_text_primary</item>
        <item name="alertDialogTheme">@style/AlertDialogTheme</item>
    </style>
    <style name="Theme.Inklet.Dark" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/dark_accent</item>
        <item name="colorPrimaryDark">@color/dark_bg</item>
        <item name="colorAccent">@color/dark_accent</item>
        <item name="android:windowBackground">@color/dark_bg</item>
        <item name="android:statusBarColor">@color/dark_bg</item>
        <item name="android:navigationBarColor">@color/dark_bg</item>
        <item name="android:textColorPrimary">@color/dark_text_primary</item>
        <item name="alertDialogTheme">@style/AlertDialogTheme.Dark</item>
    </style>
    <style name="Theme.Inklet.Dark.Splash" parent="Theme.Inklet.Dark">
        <item name="android:windowBackground">@color/dark_bg</item>
    </style>
    <style name="Theme.Inklet.Splash" parent="Theme.Inklet">
        <item name="android:windowBackground">@color/light_bg</item>
    </style>
</resources>